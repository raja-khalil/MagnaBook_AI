# =============================================================
# MagnaBook AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env.
# =============================================================

# ─── Aplicação ────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_NAME=MagnaBook AI
APP_VERSION=0.1.0
SECRET_KEY=change-me-to-a-random-256-bit-secret
DEBUG=true
LOG_LEVEL=INFO

# ─── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Banco de Dados (PostgreSQL) ──────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=magnabook
POSTGRES_USER=magnabook_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Cache / Fila (Redis) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ─── Anthropic Claude API ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192

# ─── Armazenamento ────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3
STORAGE_ROOT=./storage

# S3 (apenas se STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=magnabook-storage

# ─── Autenticação / JWT ───────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── E-mail (opcional) ────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@magnabook.ai
